FROM golang:1.25 AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /infracost-collector ./cmd/collector

FROM nvidia/cuda:12.4.1-base-ubuntu22.04

COPY --from=builder /infracost-collector /usr/local/bin/infracost-collector
ENTRYPOINT ["/usr/local/bin/infracost-collector"]
