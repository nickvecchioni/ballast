{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source pointing at ballast metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "heatmap", "name": "Heatmap", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Cluster GPU Spend",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "sum(ballast_pod_cost_per_hour_usd)",
          "legendFormat": "Total $/hr",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active GPUs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "count(ballast_gpu_utilization_percent)",
          "legendFormat": "GPUs",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg GPU Utilization",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 60 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "avg(ballast_gpu_utilization_percent)",
          "legendFormat": "Avg Util %",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Estimated Monthly Spend",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10000 },
              { "color": "red", "value": 50000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(ballast_pod_cost_per_hour_usd) * 730",
          "legendFormat": "Projected Monthly",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Per-Pod GPU Cost/hr",
      "description": "Real-time per-pod GPU cost based on utilization and GPU pricing.",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #cost" },
            "properties": [
              { "id": "displayName", "value": "Cost/hr" },
              { "id": "unit", "value": "currencyUSD" },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 1 },
                  { "color": "red", "value": 5 }
                ]
              }}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #util" },
            "properties": [
              { "id": "displayName", "value": "GPU Util %" },
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "yellow", "value": 30 },
                  { "color": "green", "value": 60 }
                ]
              }}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #mem" },
            "properties": [
              { "id": "displayName", "value": "Memory Used" },
              { "id": "unit", "value": "bytes" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #power" },
            "properties": [
              { "id": "displayName", "value": "Power (W)" },
              { "id": "unit", "value": "watt" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          { "displayName": "Cost/hr", "desc": true }
        ],
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "namespace": "Namespace",
              "pod": "Pod",
              "gpu_type": "GPU Type",
              "node": "Node"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "ballast_pod_cost_per_hour_usd{namespace=~\"$namespace\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "cost"
        },
        {
          "expr": "avg by (pod, namespace, node) (ballast_gpu_utilization_percent{namespace=~\"$namespace\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "util"
        },
        {
          "expr": "sum by (pod, namespace, node) (ballast_gpu_memory_used_bytes{namespace=~\"$namespace\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "mem"
        },
        {
          "expr": "sum by (pod, namespace, node) (ballast_gpu_power_watts{namespace=~\"$namespace\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "power"
        }
      ]
    },
    {
      "title": "GPU Utilization by Node",
      "description": "Heatmap showing GPU utilization across nodes over time.",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": true,
        "calculation": {
          "xBuckets": { "mode": "size", "value": "1m" },
          "yBuckets": { "mode": "count", "value": "20" }
        },
        "cellGap": 1,
        "color": {
          "mode": "scheme",
          "scheme": "Oranges",
          "fill": "opacity",
          "exponent": 0.5,
          "steps": 64
        },
        "yAxis": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "tooltip": {
          "show": true
        },
        "legend": { "show": true }
      },
      "targets": [
        {
          "expr": "ballast_gpu_utilization_percent{namespace=~\"$namespace\"}",
          "legendFormat": "{{ node }}/{{ gpu_uuid }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cost by Namespace",
      "description": "Breakdown of GPU spend by Kubernetes namespace.",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"],
          "calcs": ["lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "sum by (namespace) (ballast_pod_cost_per_hour_usd)",
          "legendFormat": "{{ namespace }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Cluster GPU Spend Over Time",
      "description": "Aggregate GPU cost/hr across all pods, tracked over time.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "axisLabel": "$/hr"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      },
      "targets": [
        {
          "expr": "sum(ballast_pod_cost_per_hour_usd)",
          "legendFormat": "Total Cluster $/hr",
          "refId": "A"
        },
        {
          "expr": "sum by (namespace) (ballast_pod_cost_per_hour_usd)",
          "legendFormat": "{{ namespace }}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "GPU Utilization Over Time",
      "description": "Per-pod GPU utilization tracked over time.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "avg by (pod, namespace) (ballast_gpu_utilization_percent{namespace=~\"$namespace\"})",
          "legendFormat": "{{ namespace }}/{{ pod }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "GPU Power Draw Over Time",
      "description": "Power consumption per GPU over time.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "ballast_gpu_power_watts{namespace=~\"$namespace\"}",
          "legendFormat": "{{ namespace }}/{{ pod }}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["ballast", "gpu", "kubernetes", "cost"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(ballast_pod_cost_per_hour_usd, namespace)",
        "includeAll": true,
        "multi": true,
        "name": "namespace",
        "options": [],
        "query": { "query": "label_values(ballast_pod_cost_per_hour_usd, namespace)", "refId": "A" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ballast - GPU Inference Cost Attribution",
  "uid": "ballast-gpu-cost",
  "version": 1
}
