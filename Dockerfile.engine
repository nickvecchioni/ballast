FROM golang:1.25 AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /infracost-engine ./cmd/engine

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /infracost-engine /usr/local/bin/infracost-engine
ENTRYPOINT ["/usr/local/bin/infracost-engine"]
